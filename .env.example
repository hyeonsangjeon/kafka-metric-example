# Provider: simulated (default), ollama, or foundry.
# AI_MODE remains a legacy alias only when AI_PROVIDER is absent.
AI_PROVIDER=simulated
EVENT_TRANSPORT=kafka
APP_PORT=8080

# Ollama (required only when AI_PROVIDER=ollama).
# The adapter calls the OpenAI-compatible /v1/responses endpoint and refuses a
# non-loopback URL by default. OLLAMA_MODEL must name a model pulled locally.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=
OLLAMA_REQUIRE_LOOPBACK=true

# Microsoft Foundry (required only when AI_PROVIDER=foundry).
# Copy the project endpoint exactly from the Foundry project welcome page.
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT
FOUNDRY_MODEL=YOUR-FIXED-DEPLOYMENT

# Optional Model Router comparison. The profile value is display/validation
# metadata; configure Balanced/Cost/Quality on the deployment itself.
FOUNDRY_ROUTER_MODEL=YOUR-MODEL-ROUTER-DEPLOYMENT
FOUNDRY_ROUTER_PROFILE=balanced

# Safety cap for paid/cloud requests in a single run.
MAX_CLOUD_REQUESTS_PER_RUN=10

# Kafka defaults used by Docker Compose.
KAFKA_BOOTSTRAP_SERVERS=broker:19092
KAFKA_TOPIC=foundry.telemetry.v1
KAFKA_DLQ_TOPIC=foundry.telemetry.dlq.v1
